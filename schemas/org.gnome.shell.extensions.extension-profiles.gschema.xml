<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.extension-profiles"
          path="/org/gnome/shell/extensions/extension-profiles/">

    <key name="profiles" type="s">
      <default>'{}'</default>
      <summary>Extension profiles</summary>
      <description>JSON object mapping profile names to arrays of extension UUIDs.</description>
    </key>

    <key name="active-profile" type="s">
      <default>''</default>
      <summary>Active profile name</summary>
    </key>

    <key name="startup-mode" type="s">
      <default>'none'</default>
      <summary>Startup behaviour</summary>
      <description>One of: "none", "last", "default".</description>
    </key>

    <key name="default-profile" type="s">
      <default>''</default>
      <summary>Default profile name</summary>
      <description>Profile to apply on login when startup-mode is "default".</description>
    </key>

  </schema>
</schemalist>
